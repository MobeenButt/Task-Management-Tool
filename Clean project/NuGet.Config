<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Keep any other sources you use; ensure nuget.org is present -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <!-- Required for your current errors -->
      <package pattern="Swashbuckle.*" />
      <package pattern="dotnet-ef" />

      <!-- Common dependencies -->
      <package pattern="Microsoft.*" />
      <package pattern="System.*" />

      <!-- Make nuget.org the default source for everything else -->
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>